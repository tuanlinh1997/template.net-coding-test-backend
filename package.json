{
  "name": "api",
  "version": "0.0.1",
  "description": "api",
  "author": "Linh LT",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:local": "yarn lint && cross-env NODE_ENV=local nest start --watch",
    "start:dev": "cross-env NODE_ENV=development node dist/main",
    "start:staging": "cross-env NODE_ENV=staging node dist/main",
    "start:pilot": "cross-env NODE_ENV=pilot node dist/main",
    "start:debug": "cross-env NODE_ENV=local nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production nest start --watch",
    "deploy:stag": "cross-env NODE_ENV=staging pm2 start dist/main.js --time -o logs/log.log -e errors/error.log --name api-hst",
    "lint": "eslint \"src/**/*.ts\" --fix --no-ignore",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration": "nest start --watch && ts-node ./node_modules/typeorm/cli.js migration:run",
    "build:dev": "nest build && pm2 start pm2.yaml",
    "build:stag": "nest build && NODE_PORT=5071 pm2 start pm2.json -n api-smart-cms-htv --env staging",
    "build:pilot": "nest build && NODE_PORT=5071 pm2 start pm2.json -n api-smart-cms-htv --env pilot",
    "build:prod": "nest build && NODE_PORT=5071 pm2 start pm2.json -n api-smart-cms-htv --env production",
    "pm2:delete": "pm2 delete api-smart-cms-htv",
    "build-docker:prod": "cross-env NODE_ENV=production pm2 start dist/main.js --time -o logs/log.log -e errors/error.log --name api-hst"
  },
  "dependencies": {
    "@bull-board/express": "^5.9.2",
    "@fastify/compress": "^6.4.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/static": "^6.11.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/cache-manager": "^2.1.1",
    "@nestjs/common": "^10.2.4",
    "@nestjs/config": "^3.0.1",
    "@nestjs/core": "^10.2.4",
    "@nestjs/jwt": "^10.1.1",
    "@nestjs/microservices": "^10.2.7",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-fastify": "^10.2.4",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/swagger": "^7.1.10",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/crypto-js": "^4.1.2",
    "@types/md5": "^2.3.2",
    "@types/multer": "^1.4.9",
    "axios": "^1.5.0",
    "bcrypt": "^5.1.1",
    "bloom-filters": "^3.0.2",
    "builder-pattern": "^2.2.0",
    "cache-manager": "^5.3.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.3.1",
    "eslint-plugin-unused-imports": "^4.0.0",
    "exceljs": "^4.4.0",
    "fastify-multer": "^2.0.3",
    "geoip-lite": "1.4.7",
    "image-size": "^1.0.2",
    "joi": "^17.10.1",
    "js-base64": "^3.7.5",
    "js-sha256": "^0.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "mongoose": "^9.3.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "nestjs-typeorm-paginate": "^4.0.4",
    "openai": "^6.33.0",
    "otplib": "^12.0.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "path": "^0.12.7",
    "qrcode": "^1.5.3",
    "qs": "^6.11.2",
    "reflect-metadata": "^0.1.13",
    "request-ip": "^3.3.0",
    "rimraf": "^5.0.1",
    "rxjs": "^7.2.0",
    "sharp": "^0.32.6",
    "typeorm": "^0.3.17",
    "uuid": "9.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.1.17",
    "@nestjs/schematics": "^10.0.2",
    "@nestjs/testing": "^10.2.4",
    "@swc/cli": "^0.1.62",
    "@swc/core": "1.3.80",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/lodash": "^4.14.201",
    "@types/node": "^20.5.9",
    "@types/passport-local": "^1.0.35",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.6.4",
    "prettier": "^3.0.3",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.4.4",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "resolutions": {
    "uuid": "9.0.1"
  }
}
